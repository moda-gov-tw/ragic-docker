function ifThePriceIsNegative() {
    var paramSheet = db.getAPIQuery("/ragicforms39/20004");    
    var parame = paramSheet.getAPIResult();  
    var overtimeSubtable = parame.getSubtableSize(3005149);
   
	var a = param.getNewValue(3005220).split('/');
    var b = 0;
   
    for (var j = 0; j < a.length-1; j++) {
      for (var i = 0; i < overtimeSubtable; i++) {
      	var overtimeCtgy = parame.getSubtableFieldValue(3005149, i, 3005146);  
        if (overtimeCtgy == a[j]) {
        	b++; 
        }   
      }
    }
    if (b == a.length-1) {
      response.setStatus('SUCCESS');
      response.setMessage('儲存成功');} 
    else {
      response.setStatus('INVALID');
      response.setMessage('參數表單無對應[加班類別]，請檢查參數表單');
      response.setMessage(b);
      response.setMessage(a.length-1);
    
    }
}  
  
 
