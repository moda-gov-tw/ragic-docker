function compLeaveGen(recordId) {   

	var thisSheet = db.getAPIQuery("/ragicforms39/20009");  
  	var LeaveSheet = db.getAPIQuery("/ragicforms39/20011");   
  	var thisEntry = thisSheet.getAPIEntry(recordId);  
	var thisEmployeeEmail = thisEntry.getFieldValue(3005274); 
    var today = new Date(new Date().getTime() + account.getTimeZoneOffset());
 
	LeaveSheet.addFilter(3000940, '=', thisEmployeeEmail); 
  
	var result = LeaveSheet.getAPIResult(); 
    var compensatoryHours = Number(thisEntry.getFieldValue(3005297));  
    var rows = result.getSubtableSize(3005289);  
    var haveCompLeave = 'no'; 
    
    for (var j = 0; j < rows; j++ ) {
      	var vacType = result.getSubtableFieldValue(3005289,j,3005281);
                
      	if (vacType == '補休') {
        	var subIndex = result.getSubtableRootNodeId(3005289,j);
            var orglHours = Number(result.getSubtableFieldValue(3005289,j,3005283));
        	result.setSubtableFieldValue(3005283,subIndex,compensatoryHours+orglHours); 
        	haveCompLeave = 'yes';  
        }
    }    
    if (haveCompLeave == 'no')  {
    	result.setSubtableFieldValue(3005282,-100,today.getFullYear()); 
      	result.setSubtableFieldValue(3005283,-100,compensatoryHours); 
      	result.setSubtableFieldValue(3005281,-100,"補休");                
    }    		
    
    thisEntry.setFieldValue(3005298,'Yes');
    thisEntry.save(); 
    result.recalculateAllFormulas();   
    result.save(); 
    response.setMessage('已產生補休'); 
    response.setStatus('SUCCESS');
}
