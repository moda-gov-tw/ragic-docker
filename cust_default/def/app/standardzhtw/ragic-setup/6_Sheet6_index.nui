PRE_WORKFLOW_START
var internalDomain=db.getDBProperty('INTERNAL_DOMAIN');
var newEmail=param.getNewValue(621);
if(!internalDomain){
  response.setStatus('INVALID');
  response.setMessage('外部使用者未啟用.');
}
else if(internalDomain && newEmail && newEmail.indexOf(internalDomain) !== -1){
  response.setStatus('INVALID');
  response.setMessage('你應該是內部使用者，不是外部使用者: '+internalDomain);
}
SHEET_SCOPE_START
function approveExternalUserRequest(nodeId){
  var json=db.entryCopier(JSON.stringify({
      'THIS_PATH':'/ragic-setup/6',
      'THIS_NODEID':nodeId,
      'NEW_PATH':'/ragic-setup/5',
      'EXEC_WORKFLOW':true,
      'COPY':{
        '1':'621',
        '4':'622',
        '610':'623',
        '609':'624',
        '613':'625',
      }
    }), response);

  var query=db.getAPIQuery('/ragic-setup/6');
  var sourceEntry=query.getAPIEntry(nodeId);
  sourceEntry.setFieldValue(627,'核可');
  sourceEntry.save();
}
function rejectExternalUserRequest(nodeId){
  var query=db.getAPIQuery('/ragic-setup/6');
  var sourceEntry=query.getAPIEntry(nodeId);

  if(sourceEntry.getFieldValue(627)=='核可'){
    response.setMessage('核可的使用者不能被拒絕，您需要到外部使用者管理表單去把這名使用者刪除。');
    return;
  }

  sourceEntry.setFieldValue(627,'拒絕');
  sourceEntry.save();
}
